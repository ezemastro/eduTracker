---
import type { Group, Student } from "@/lib/database";
import StudentImage from "./StudentImage.astro";

interface Props {
  student: Student;
  group?: Group;
  class?: string;
  hideName?: boolean;
  hideGroup?: boolean;
  subGroup?: "green" | "yellow" | null;
}
const { student, group, class: cardClass, hideName, hideGroup, subGroup } = Astro.props;
---

<a
  href={`/students/${student.id}`}
  class={"card shadow bg-base-100 flex flex-col h-full card-xs sm:card-md overflow-hidden " +
    (cardClass || "")}
>
  {subGroup && (
    <div
      class={`h-1.5 w-full shrink-0 ${subGroup === "green" ? "bg-green-500" : "bg-yellow-500"}`}
    />
  )}
  <figure class="shrink-0">
    <StudentImage src={student.image} gender={student.gender} />
  </figure>

  {
    !hideName || (!hideGroup && group) ? (
      <div class={"card-body " + (hideGroup && "items-center")}>
        {!hideName && (
          <h2 class="card-title text-base sm:text-lg">
            {student.name} {student.lastName}
          </h2>
        )}
        {group && !hideGroup && (
          <p class="text-sm opacity-70">
            Clase: {group.year}
            {group.letter}
          </p>
        )}
      </div>
    ) : null
  }
</a>
