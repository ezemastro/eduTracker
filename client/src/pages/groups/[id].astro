---
import SubGroupBoard from "@/components/SubGroupBoard.astro";
import Layout from "@/layouts/Layout.astro";
import { db } from "@/lib/database";

const { id } = Astro.params;
if (!id || isNaN(Number(id))) {
  return Astro.redirect("/groups");
}
const group = await db.groups.getById(Number(id));
if (!group) {
  return Astro.redirect("/groups");
}

const students = await db.students.getByGroupId(Number(id));
---

<Layout title={group.year + "° " + group.letter + " - Edu Tracker"}>
  <div class="flex w-full h-full flex-col p-4">
    <h1 class="text-2xl text-center mb-4">{group.year}° {group.letter}</h1>
    <SubGroupBoard
      students={students.map((student) => ({
        ...student,
        letter: group.letter,
        year: group.year,
      }))}
    />
  </div>
</Layout>
