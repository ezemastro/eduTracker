---
import StudentList from "@/components/StudentList.astro";
import Layout from "@/layouts/Layout.astro";
import { db } from "@/lib/database";

// Get search params
const searchParams = Astro.url.searchParams;
const photoFilter = searchParams.get("photo"); // "with", "without" or null
const sortFilter = searchParams.get("sort");
const sortDir = searchParams.get("dir") || "asc";
const selectedGroups = searchParams.getAll("groups");
const query = searchParams.get("q")?.toLowerCase() || "";

const hasFilters = searchParams.size > 0;
const showNames = hasFilters ? searchParams.has("showNames") : true;
const showGroups = hasFilters ? searchParams.has("showGroups") : true;

// Fetch students
let students = await db.students.getAll();

// Search by query
if (query) {
  students = students.filter(
    (s) =>
      s.name.toLowerCase().includes(query) ||
      s.lastName.toLowerCase().includes(query),
  );
}

// Get unique groups for filter options
const uniqueGroups = [
  ...new Map(
    students.map((s) => [
      s.group_id,
      { id: s.group_id, year: s.year, letter: s.letter },
    ]),
  ).values(),
].sort((a, b) => a.year - b.year || a.letter.localeCompare(b.letter));

// Filter students by photo
if (photoFilter === "with") {
  students = students.filter((s) => s.image);
} else if (photoFilter === "without") {
  students = students.filter((s) => !s.image);
}

// Filter students by selected groups
if (selectedGroups.length > 0) {
  students = students.filter((s) =>
    selectedGroups.includes(s.group_id.toString()),
  );
}

// Sort students
if (sortFilter) {
  students.sort((a, b) => {
    let modifier = sortDir === "asc" ? 1 : -1;

    if (sortFilter === "name") return a.name.localeCompare(b.name) * modifier;
    if (sortFilter === "lastName")
      return a.lastName.localeCompare(b.lastName) * modifier;
    if (sortFilter === "group") {
      if (a.year === b.year) return a.letter.localeCompare(b.letter) * modifier;
      return (a.year - b.year) * modifier;
    }
    if (sortFilter === "difficulty")
      return (a.ease_factor - b.ease_factor) * modifier;
    return 0;
  });
}
---

<Layout>
  <header class="py-4">
    <h1 class="text-3xl font-bold text-center">Estudiantes</h1>
  </header>
  <main class="p-4 space-y-4">
    <form method="GET" class="flex flex-col gap-4 items-center justify-center">
      <label class="input input-bordered flex items-center gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          fill="currentColor"
          class="w-4 h-4 opacity-70"
          ><path
            fill-rule="evenodd"
            d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.754-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
            clip-rule="evenodd"></path></svg
        >
        <input type="text" name="q" placeholder="Search" value={query} />
      </label>

      <div
        class="flex gap-8 justify-center items-start shadow rounded-box p-4 flex-wrap"
      >
        <fieldset class="flex flex-col gap-4 min-w-52">
          <span class="text-sm font-semibold text-base-content/70 text-center"
            >Visualización</span
          >
          <div class="flex flex-col gap-3">
            <div class="form-control">
              <label class="label cursor-pointer gap-4 flex justify-between">
                <span class="label-text">Mostrar nombres</span>
                <input
                  type="checkbox"
                  name="showNames"
                  class="toggle toggle-primary"
                  checked={showNames}
                />
              </label>
            </div>

            <div class="form-control">
              <label class="label cursor-pointer gap-4 flex justify-between">
                <span class="label-text">Mostrar grupo</span>
                <input
                  type="checkbox"
                  name="showGroups"
                  class="toggle toggle-secondary"
                  checked={showGroups}
                />
              </label>
            </div>
          </div>
        </fieldset>
        <fieldset class="flex flex-col gap-3 items-center min-w-52">
          <span class="text-sm font-semibold text-base-content/70 text-center">
            Filtrar por foto
          </span>
          <div class="join">
            <input
              class="btn join-item checked:btn-accent checked:btn-active"
              type="checkbox"
              name="photo"
              value="with"
              aria-label="Con foto"
              checked={photoFilter === "with"}
              data-photo-filter
            />
            <input
              class="btn join-item checked:btn-warning checked:btn-active"
              type="checkbox"
              name="photo"
              value="without"
              aria-label="Sin foto"
              checked={photoFilter === "without"}
              data-photo-filter
            />
          </div>
        </fieldset>

        <fieldset class="flex flex-col space-y-2 flex-1 min-w-75 max-w-xl">
          <span class="text-sm font-semibold text-base-content/70 text-center"
            >Filtrar por curso</span
          >
          <div class="flex flex-wrap gap-2 justify-center">
            {
              uniqueGroups.map((g) => (
                <input
                  class="btn"
                  type="checkbox"
                  name="groups"
                  value={g.id}
                  aria-label={`${g.year}° ${g.letter}`}
                  checked={selectedGroups.includes(g.id.toString())}
                />
              ))
            }
          </div>
        </fieldset>

        <fieldset class="flex flex-col gap-2 min-w-64 items-center">
          <span class="text-sm font-semibold text-base-content/70 text-center"
            >Ordenar</span
          >

          <div class="join w-full justify-center">
            <select
              name="sort"
              class="select select-bordered join-item w-full max-w-40"
            >
              <option value="" selected={!sortFilter}>Seleccionar</option>
              <option value="name" selected={sortFilter === "name"}
                >Nombre</option
              >
              <option value="lastName" selected={sortFilter === "lastName"}
                >Apellido</option
              >
              <option value="group" selected={sortFilter === "group"}
                >Curso</option
              >
              <option value="difficulty" selected={sortFilter === "difficulty"}
                >Dificultad</option
              >
            </select>

            <label class="btn btn-square join-item swap swap-rotate">
              <input
                type="checkbox"
                name="dir"
                value="desc"
                checked={sortDir === "desc"}
              />

              <svg
                class="swap-on fill-current w-5 h-5"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
              >
                <path
                  d="M13 20H11V8L5.5 13.5L4.08 12.08L12 4.16L19.92 12.08L18.5 13.5L13 8V20Z"
                ></path>
              </svg>

              <svg
                class="swap-off fill-current w-5 h-5"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
              >
                <path
                  d="M11 4H13V16L18.5 10.5L19.92 11.92L12 19.84L4.08 11.92L5.5 10.5L11 16V4Z"
                ></path>
              </svg>
            </label>
          </div>
        </fieldset>
      </div>
      <div class="flex justify-center gap-4">
        <a href={Astro.url.pathname} class="btn btn-ghost">Limpiar</a>
        <button type="submit" class="btn btn-primary px-8" disabled>
          Aplicar Filtros
        </button>
      </div>
    </form>
    <StudentList
      students={students}
      showNames={showNames}
      showGroups={showGroups}
    />
  </main>
</Layout>

<script>
  const form = document.querySelector("form");
  const submitButton = document.querySelector("button[type='submit']");
  form?.addEventListener("change", () => {
    submitButton?.removeAttribute("disabled");
  });

  const photoFilters = document.querySelectorAll("[data-photo-filter]");
  photoFilters.forEach((input) => {
    input.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement;
      if (target.checked) {
        photoFilters.forEach((other) => {
          if (other !== target) (other as HTMLInputElement).checked = false;
        });
      }
    });
  });
</script>
