---
import MultipleChoiceCard from "@/components/MultipleChoiceCard.astro";
import ReverseCard from "@/components/ReverseCard.astro";
import TypeAnswerCard from "@/components/TypeAnswerCard.astro";
import Layout from "@/layouts/Layout.astro";
import { getNextFlashcard } from "@/lib/flashcards/getNext";
import type { FlashcardMode } from "@/lib/flashcards/scoring";
import { db } from "@/lib/database";

const searchParams = Astro.url.searchParams;

let tracking = false;
let mode: FlashcardMode = "multiple";

if (searchParams.has("configured")) {
  tracking = searchParams.has("tracking");
  const m = searchParams.get("mode");
  if (m === "type" || m === "reverse") mode = m;

  Astro.cookies.set("tracking_pref", tracking ? "true" : "false", {
    path: "/",
    maxAge: 31536000,
  });
  Astro.cookies.set("mode_pref", mode, {
    path: "/",
    maxAge: 31536000,
  });
} else {
  const trackingCookie = Astro.cookies.get("tracking_pref")?.value;
  if (trackingCookie === "true") tracking = true;

  const modeCookie = Astro.cookies.get("mode_pref")?.value;
  if (modeCookie === "type" || modeCookie === "reverse") mode = modeCookie;
}

const selectedGroups = searchParams.getAll("groups").map((g) => Number(g));
const allGroups = await db.groups.getAll();

const { status, flashcard } = await getNextFlashcard({
  groups: selectedGroups,
  tracking,
  mode,
});
---

<Layout>
  <div class="absolute top-4 right-4 z-10">
    <button
      class="btn btn-circle btn-ghost shadow bg-base-100"
      onclick="configModal.showModal()"
    >
      ⚙️
    </button>
  </div>

  <main class="flex flex-col grow justify-center items-center p-4">
    {
      status === "done" && (
        <div class="text-center space-y-4">
          <h2 class="text-2xl font-bold">¡Al día!</h2>
          <p>No hay más flashcards por repasar hoy.</p>
          <button class="btn btn-primary" onclick="configModal.showModal()">
            Cambiar Configuración
          </button>
        </div>
      )
    }

    {
      flashcard?.mode === "multiple" && (
        <MultipleChoiceCard
          studentId={flashcard.id}
          image={flashcard.image}
          options={flashcard.options}
          tracking={tracking}
        />
      )
    }

    {
      flashcard?.mode === "type" && (
        <TypeAnswerCard studentId={flashcard.id} image={flashcard.image} />
      )
    }

    {
      flashcard?.mode === "reverse" && (
        <ReverseCard
          studentId={flashcard.id}
          name={flashcard.name}
          imageOptions={flashcard.imageOptions}
          tracking={tracking}
        />
      )
    }

    {
      flashcard && (
        <div class="mt-8">
          <button
            id="btn-next"
            class="btn btn-primary btn-wide opacity-0 pointer-events-none transition-opacity duration-200"
          >
            Siguiente
          </button>
        </div>
      )
    }
  </main>

  <dialog id="configModal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg mb-4">Configuración de Práctica</h3>
      <form method="GET" class="space-y-6">
        <input type="hidden" name="configured" value="yes" />

        <div class="form-control bg-base-200 p-4 rounded-box">
          <span class="label-text font-bold mb-3">Modo de juego</span>
          <div class="flex flex-col gap-2">
            <label class="label cursor-pointer justify-start gap-3">
              <input
                type="radio"
                name="mode"
                value="multiple"
                class="radio radio-primary"
                checked={mode === "multiple"}
              />
              <span class="label-text">Opción Múltiple</span>
            </label>
            <label class="label cursor-pointer justify-start gap-3">
              <input
                type="radio"
                name="mode"
                value="type"
                class="radio radio-primary"
                checked={mode === "type"}
              />
              <span class="label-text">Escribir Nombre</span>
            </label>
            <label class="label cursor-pointer justify-start gap-3">
              <input
                type="radio"
                name="mode"
                value="reverse"
                class="radio radio-primary"
                checked={mode === "reverse"}
              />
              <span class="label-text">Reconocer Cara</span>
            </label>
          </div>
        </div>

        <div class="form-control bg-base-200 p-4 rounded-box">
          <label class="label cursor-pointer flex justify-between">
            <div>
              <span class="label-text font-bold">Seguimiento Activo</span>
              <div class="text-xs opacity-70 mt-1">
                Guarda tu progreso (Algoritmo SM-2)
              </div>
            </div>
            <input
              type="checkbox"
              name="tracking"
              value="true"
              class="toggle toggle-primary"
              checked={tracking}
            />
          </label>
        </div>

        <div class="form-control">
          <span class="label-text font-bold mb-3">Filtrar por cursos</span>
          <div class="flex flex-wrap gap-2">
            {
              allGroups.map((g) => (
                <input
                  type="checkbox"
                  class="btn btn-sm"
                  name="groups"
                  value={g.id}
                  aria-label={`${g.year}° ${g.letter}`}
                  checked={selectedGroups.includes(g.id)}
                />
              ))
            }
          </div>
        </div>

        <div class="modal-action">
          <button
            type="button"
            class="btn btn-ghost"
            onclick="configModal.close()">Cancelar</button
          >
          <button type="submit" class="btn btn-primary"
            >Aplicar y Recargar</button
          >
        </div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>cerrar</button>
    </form>
  </dialog>
</Layout>

<script>
  const nextButton = document.getElementById("btn-next");

  window.addEventListener("flashcard-answered", () => {
    nextButton?.classList.remove("opacity-0", "pointer-events-none");
  });

  nextButton?.addEventListener("click", async () => {
    nextButton.disabled = true;
    nextButton.innerHTML =
      '<span class="loading loading-spinner"></span> Guardando...';

    // Emit event so individual card components can save their feedback
    window.dispatchEvent(new CustomEvent("flashcard-next"));

    // Small delay to let async feedback requests fire
    await new Promise((r) => setTimeout(r, 300));

    // Clean URL and reload only with the selected groups and mode
    const url = new URL(window.location.href);
    url.searchParams.delete("configured");
    url.searchParams.delete("tracking");
    window.location.href = url.toString();
  });
</script>
